{
  "manifest_version": 3,
  "name": "Kognetic",
  "version": "1.0",
  "description": "Kognetic Cognitive second brain",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Kognetic"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "https://*.vercel.app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
